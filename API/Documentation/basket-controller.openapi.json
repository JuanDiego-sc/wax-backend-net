{
  "openapi": "3.0.3",
  "info": {
    "title": "WAX API - Basket",
    "description": "Endpoints for shopping basket management: retrieving the basket, adding items, and removing items.",
    "version": "1.0.0",
    "contact": {
      "name": "WAX Backend Team"
    }
  },
  "servers": [
    {
      "url": "https://localhost:5007",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Basket",
      "description": "Shopping basket operations: retrieval, item addition, and item removal"
    }
  ],
  "paths": {
    "/api/Basket": {
      "get": {
        "tags": ["Basket"],
        "summary": "Get basket",
        "description": "Returns the current basket for the session. The basket is identified via a cookie set by the server. Returns an empty basket if no basket ID is found.",
        "operationId": "Basket_GetBasket",
        "responses": {
          "200": {
            "description": "Basket retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasketDto"
                },
                "example": {
                  "basketId": "basket-xyz-789",
                  "items": [
                    {
                      "productId": "prod-abc-123",
                      "productName": "Technics SL-1200",
                      "price": 120000,
                      "pictureUrl": "https://cdn.example.com/products/sl1200.jpg",
                      "brand": "Technics",
                      "type": "Turntable",
                      "quantity": 2
                    }
                  ],
                  "clientSecret": null,
                  "paymentIntentId": null
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Basket"],
        "summary": "Add item to basket",
        "description": "Adds a product with the specified quantity to the basket. If no basket exists for the current session, a new one is created and its ID is stored in a cookie.",
        "operationId": "Basket_AddItemToBasket",
        "parameters": [
          {
            "name": "productId",
            "in": "query",
            "description": "Unique identifier of the product to add",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "prod-abc-123"
          },
          {
            "name": "quantity",
            "in": "query",
            "description": "Number of units to add",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "example": 2
          }
        ],
        "responses": {
          "200": {
            "description": "Item added to basket successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasketDto"
                },
                "example": {
                  "basketId": "basket-xyz-789",
                  "items": [
                    {
                      "productId": "prod-abc-123",
                      "productName": "Technics SL-1200",
                      "price": 120000,
                      "pictureUrl": "https://cdn.example.com/products/sl1200.jpg",
                      "brand": "Technics",
                      "type": "Turntable",
                      "quantity": 2
                    }
                  ],
                  "clientSecret": null,
                  "paymentIntentId": null
                }
              }
            }
          },
          "400": {
            "description": "Product not found or insufficient stock"
          }
        }
      },
      "delete": {
        "tags": ["Basket"],
        "summary": "Remove item from basket",
        "description": "Removes the specified quantity of a product from the basket. If the resulting quantity reaches zero, the item is removed entirely.",
        "operationId": "Basket_RemoveItemFromBasket",
        "parameters": [
          {
            "name": "productId",
            "in": "query",
            "description": "Unique identifier of the product to remove",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "prod-abc-123"
          },
          {
            "name": "quantity",
            "in": "query",
            "description": "Number of units to remove",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Item removed from basket successfully"
          },
          "400": {
            "description": "Item not found in basket or invalid quantity"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BasketDto": {
        "type": "object",
        "description": "Shopping basket representation",
        "properties": {
          "basketId": {
            "type": "string",
            "description": "Unique identifier of the basket",
            "example": "basket-xyz-789"
          },
          "items": {
            "type": "array",
            "description": "List of items in the basket",
            "items": {
              "$ref": "#/components/schemas/BasketItemDto"
            }
          },
          "clientSecret": {
            "type": "string",
            "nullable": true,
            "description": "Stripe PaymentIntent client secret, set when a payment intent has been created",
            "example": "pi_3Abc_secret_xyz"
          },
          "paymentIntentId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe PaymentIntent ID associated with this basket",
            "example": "pi_3AbcXYZ123"
          }
        }
      },
      "BasketItemDto": {
        "type": "object",
        "description": "A single item within the shopping basket",
        "properties": {
          "productId": {
            "type": "string",
            "description": "Unique identifier of the product",
            "example": "prod-abc-123"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Technics SL-1200"
          },
          "price": {
            "type": "integer",
            "format": "int64",
            "description": "Unit price of the product in cents",
            "example": 120000
          },
          "pictureUrl": {
            "type": "string",
            "description": "URL of the product image",
            "example": "https://cdn.example.com/products/sl1200.jpg"
          },
          "brand": {
            "type": "string",
            "description": "Product brand",
            "example": "Technics"
          },
          "type": {
            "type": "string",
            "description": "Product category type",
            "example": "Turntable"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units of this product in the basket",
            "example": 2
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": ".AspNetCore.Identity.Application",
        "description": "ASP.NET Identity authentication cookie. Obtained via POST /api/login?useCookies=true."
      }
    }
  }
}
