{
  "openapi": "3.0.3",
  "info": {
    "title": "WAX API - Admin",
    "description": "Administrative endpoints for user management, role assignment, and account enable/disable operations. Requires Admin role.",
    "version": "1.0.0",
    "contact": {
      "name": "WAX Backend Team"
    }
  },
  "servers": [
    {
      "url": "https://localhost:5007",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Admin",
      "description": "User administration: listing, role management, and account status control"
    }
  ],
  "paths": {
    "/api/Admin": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all users",
        "description": "Returns all registered users with their assigned roles. Intended for admin dashboard user management.",
        "operationId": "Admin_GetUsers",
        "responses": {
          "200": {
            "description": "List of users retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserDto"
                  }
                },
                "example": [
                  {
                    "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                    "email": "admin@wax.com",
                    "userName": "admin@wax.com",
                    "emailConfirmed": true,
                    "role": "Admin"
                  },
                  {
                    "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                    "email": "user@example.com",
                    "userName": "user@example.com",
                    "emailConfirmed": false,
                    "role": "Enrolled"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "User is not authenticated"
          },
          "403": {
            "description": "User does not have Admin role"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/api/Admin/{userId}/roles{roleName}": {
      "post": {
        "tags": ["Admin"],
        "summary": "Add role to user",
        "description": "Assigns a role to the specified user. Valid roles: Admin, Enrolled, Registered.",
        "operationId": "Admin_AddRoleToUser",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "The unique identifier of the user",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          {
            "name": "roleName",
            "in": "path",
            "description": "The role name to assign. Must be one of the valid system roles.",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["Admin", "Enrolled", "Registered"]
            },
            "example": "Registered"
          }
        ],
        "responses": {
          "200": {
            "description": "Role assigned successfully"
          },
          "400": {
            "description": "Role does not exist or assignment failed",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "string",
                      "example": "Role does not exists"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "example": ["User already in role 'Registered'."]
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "User is not authenticated"
          },
          "403": {
            "description": "User does not have Admin role"
          },
          "404": {
            "description": "User not found"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/api/Admin/{userId}/roles/{roleName}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "Remove role from user",
        "description": "Removes a role from the specified user.",
        "operationId": "Admin_RemoveUserFromRole",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "The unique identifier of the user",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          {
            "name": "roleName",
            "in": "path",
            "description": "The role name to remove",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["Admin", "Enrolled", "Registered"]
            },
            "example": "Enrolled"
          }
        ],
        "responses": {
          "200": {
            "description": "Role removed successfully"
          },
          "400": {
            "description": "Role removal failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "example": ["User is not in role 'Enrolled'."]
              }
            }
          },
          "401": {
            "description": "User is not authenticated"
          },
          "403": {
            "description": "User does not have Admin role"
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "Usuario no encontrado"
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/api/Admin/{userId}/disable": {
      "post": {
        "tags": ["Admin"],
        "summary": "Disable user account",
        "description": "Locks the user account indefinitely by setting LockoutEnd to MaxValue. The user will not be able to log in until re-enabled.",
        "operationId": "Admin_DisableUser",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "The unique identifier of the user to disable",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "responses": {
          "200": {
            "description": "User account disabled successfully"
          },
          "401": {
            "description": "User is not authenticated"
          },
          "403": {
            "description": "User does not have Admin role"
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "Usuario no encontrado"
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/api/Admin/{userId}/enable": {
      "post": {
        "tags": ["Admin"],
        "summary": "Enable user account",
        "description": "Unlocks a previously disabled user account by clearing the LockoutEnd value. The user will be able to log in again.",
        "operationId": "Admin_EnableUser",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "The unique identifier of the user to enable",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "responses": {
          "200": {
            "description": "User account enabled successfully"
          },
          "401": {
            "description": "User is not authenticated"
          },
          "403": {
            "description": "User does not have Admin role"
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "Usuario no encontrado"
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "UserDto": {
        "type": "object",
        "description": "User representation for admin operations",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique user identifier",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address",
            "example": "user@example.com"
          },
          "userName": {
            "type": "string",
            "description": "Username (same as email)",
            "example": "user@example.com"
          },
          "emailConfirmed": {
            "type": "boolean",
            "description": "Whether the user has confirmed their email address",
            "example": true
          },
          "role": {
            "type": "string",
            "nullable": true,
            "description": "Primary role assigned to the user. Null if no role assigned.",
            "enum": ["Admin", "Enrolled", "Registered", null],
            "example": "Registered"
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": ".AspNetCore.Identity.Application",
        "description": "ASP.NET Identity authentication cookie. Obtained via POST /api/login?useCookies=true. Must belong to a user with Admin role."
      }
    }
  }
}
